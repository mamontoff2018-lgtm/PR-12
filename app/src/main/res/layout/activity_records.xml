<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="🏆 ТАБЛИЦА РЕКОРДОВ 🏆"
        android:textSize="22sp"
        android:textStyle="bold"
        android:textColor="@color/purple_700"
        android:layout_marginBottom="32dp" />

    <TextView
        android:id="@+id/tvRecordInfo"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Загрузка..."
        android:textSize="18sp"
        android:gravity="center"
        android:padding="24dp"
        android:background="@drawable/settings_bg"
        android:layout_marginBottom="24dp" />

    <TextView
        android:id="@+id/tvLastGames"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Последние игры:"
        android:textSize="16sp"
        android:textStyle="bold"
        android:layout_marginBottom="8dp" />

    <TextView
        android:id="@+id/tvGameHistory"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Нет данных"
        android:textSize="14sp"
        android:padding="16dp"
        android:background="@drawable/settings_bg"
        android:layout_marginBottom="24dp" />

    <Button
        android:id="@+id/btnClearRecords"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="СБРОСИТЬ РЕКОРДЫ"
        android:textSize="16sp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnBackFromRecords"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="НАЗАД"
        android:textSize="16sp" />

</LinearLayout>