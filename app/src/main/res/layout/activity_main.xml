<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="24dp"
    android:gravity="center_horizontal">

    <ImageView
        android:layout_width="120dp"
        android:layout_height="120dp"
        android:src="@drawable/ic_wolf"
        android:contentDescription="@string/wolf_image"
        android:layout_marginBottom="24dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="@string/title_wolf_catch_eggs"
        android:textSize="24sp"
        android:textStyle="bold"
        android:textColor="@color/purple_700"
        android:layout_marginBottom="32dp" />

    <!-- Текущие настройки -->
    <TextView
        android:id="@+id/tvCurrentSettings"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/current_settings"
        android:textSize="14sp"
        android:padding="16dp"
        android:background="@drawable/settings_bg"
        android:layout_marginBottom="24dp" />

    <!-- Кнопки навигации -->
    <Button
        android:id="@+id/btnPlay"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_play"
        android:textSize="18sp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnSettings"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_settings"
        android:textSize="18sp"
        android:layout_marginBottom="12dp" />

    <Button
        android:id="@+id/btnRecords"
        android:layout_width="match_parent"
        android:layout_height="60dp"
        android:text="@string/btn_records"
        android:textSize="18sp" />

</LinearLayout>